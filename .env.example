# Trudesk Environment Variables
# Copy this file to .env and adjust values for your environment.

# ── General ──────────────────────────────────────────────
NODE_ENV=development
# TRUDESK_DOCKER=true            # Set when running inside Docker
# TRUDESK_JWTSECRET=changeme     # Override JWT secret (auto-generated if unset)
# DISABLE_RESTART=true           # Disable PM2 restart endpoint

# ── Docker Compose (used by mongo init scripts) ─────────
MONGO_INITDB_ROOT_USERNAME=trudesk_admin
MONGO_INITDB_ROOT_PASSWORD=change_me_local_please
MONGO_INITDB_DATABASE=trudesk

# ── MongoDB ──────────────────────────────────────────────
TD_MONGODB_SERVER=mongo
TD_MONGODB_PORT=27017
TD_MONGODB_DATABASE=trudesk
TD_MONGODB_USERNAME=trudesk_admin
TD_MONGODB_PASSWORD=change_me_local_please
# TD_MONGODB_SHARD=              # Replica set / shard name

# Option B: Full connection URI (overrides individual params)
# TD_MONGODB_URI=mongodb://localhost:27017/trudesk

# Use in-memory MongoDB (for testing / development without external DB)
# TD_USE_INMEM_MONGO=true

# ── Elasticsearch (optional) ─────────────────────────────
# ELASTICSEARCH_URI=http://localhost:9200
# ELASTICSEARCH_INDEX_NAME=trudesk

# ── Rate Limiting ────────────────────────────────────────
# USE_XFORWARDIP=true            # Use X-Forwarded-For header for IP detection
# USE_USERRATELIMIT=true         # Rate limit per user+IP combination

# ── Cache ────────────────────────────────────────────────
# CACHE_MEMLIMIT=2048            # In-memory cache size limit (MB)
# TIMEZONE=Europe/Berlin         # Timezone for cache timestamps
